# ESP device connection
ESP_HOST=
ESP_PORT=6053
ESP_PASSWORD=
# Noise encryption key (base64, recommended over password)
# Generate with: openssl rand -base64 32
ESP_NOISE_PSK=

# LLM configuration
# Option 1: Cloud API (e.g. OpenAI)
# LLM_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-5.4-nano
#
# Option 2: Local llama.cpp (default, no API key needed)
# LLM_URL=http://localhost:8080/v1/chat/completions

# HTTP server port for serving TTS audio files to ESP
HTTP_PORT=8888

# Home Assistant (local REST API)
# Create a long-lived access token in HA: Profile > Security > Long-Lived Access Tokens
HA_URL=http://your-ha-ip:8123
HA_TOKEN=
