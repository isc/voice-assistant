# ESP device connection
ESP_HOST=
ESP_PORT=6053
ESP_PASSWORD=
# Noise encryption key (base64, recommended over password)
# Generate with: openssl rand -base64 32
ESP_NOISE_PSK=

# LLM server (OpenAI-compatible endpoint)
LLAMA_URL=http://localhost:8080/v1/chat/completions

# HTTP server port for serving TTS audio files to ESP
HTTP_PORT=8888

# Home Assistant (local REST API)
# Create a long-lived access token in HA: Profile > Security > Long-Lived Access Tokens
HA_URL=http://your-ha-ip:8123
HA_TOKEN=
